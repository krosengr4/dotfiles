alias reload="source ~/.bashrc"
alias rld="source ~/.bashrc"
alias confbash="nvim ~/.bashrc"
alias ..="cd .."

# ENVIRONMENT
export EDITOR="nvim"
export CONFIG="$HOME/.config"

# Neovim alias
alias vi="nvim"

# Git Aliases
alias gs="git status"
alias ga="git add"
alias gaa="git add -A"
alias gcm="git commit -m"
alias gpsh="git push"
alias gpom="git push origin main"

# Go alias
alias gr="go run"
