# Config syntax crash course
# ==========================
# # Any line beginning with a # is a comment. It's not possible to put
# # a comment after a config option, since it would be interpreted as a
# # part of the value. For example, this will have a value of "#123abc":
# background = #123abc

# # Some config options have unique syntaxes for their value,
# # which is explained in the docs for that config option.
# # Just for example:
# resize-overlay-duration = 4s 200ms

##########################################################################################

# Theme and colors


#Favorite Themes
#-----------------------------
#theme = Apple classic
theme = Homebrew
#theme = Spacedust
#theme = Tearout
#theme = ayu
#theme = fahrenheit
#theme = Mona Lisa

#Other Themes
#-----------------------------
#theme = Aurora
#theme = 12-bit Rainbow
#theme = Vimbones
#theme = Cyberdyne
#theme = ENCOM
#theme = Hipster Green
#theme = phala green dark
#theme = catppuccin mocha
#theme = ciapre
#theme = fahrenheit

background-opacity = .95
background-blur = 1

window-theme = dark

# Cursor

cursor-style = block_hollow
cursor-color = #6185E4

# Font 

#font-family = Fira Code
#font-family = Hack
#font-family = JetBrains Mono
font-family = Inconsolata
#font-family = Monaco
#font-family = Menlo
#font-family = Space Mono


font-size = 18

#macos-icon = official
#macos-icon = blueprint
#macos-icon = chalkboard
#macos-icon = microchip
#macos-icon = glass
#macos-icon = holographic
#macos-icon = paper
macos-icon = retro
#macos-icon = xray

# Key-binds

keybind = cmd+d=new_split:right
keybind = cmd+s=new_split:left
keybind = cmd+e=new_tab
keybind = global:cmd+backquote=toggle_quick_terminal
keybind = cmd+p=toggle_command_palette
keybind = cmd+z=undo

# Window size and position upon opening

window-height = 40
window-width = 140

# Extras

split-divider-color = #6185E4
window-inherit-working-directory = true
window-colorspace = display-p3

window-show-tab-bar = always
macos-titlebar-style = transparent

macos-shortcuts = allow




